  "item": [
    {
      "name": "0 · Setup (auth + bootstrap)",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ok=true', () => pm.expect(body.ok).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Super-admin · Get current code (auto-rota si venció)",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "x-super-admin-key", "value": "{{super_admin_key}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/activation/current-code?tenant_slug={{tenant_slug}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "activation", "current-code"],
              "query": [{ "key": "tenant_slug", "value": "{{tenant_slug}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.test('Code de 6 dígitos', () => pm.expect(data.code).to.match(/^\\d{6}$/));",
                  "pm.collectionVariables.set('current_code', data.code);"
                ]
              }
            }
          ]
        },
        {
          "name": "Public · Verify (con code de 6 dígitos)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{current_code}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/activation/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "activation", "verify"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.test('valid=true', () => pm.expect(data.valid).to.eql(true));",
                  "pm.test('Bearer presente (64 hex)', () => pm.expect(data.activation.session_token).to.match(/^[0-9a-f]{64}$/));",
                  "pm.collectionVariables.set('session_token', data.activation.session_token);",
                  "pm.collectionVariables.set('tenant_id', data.tenant.id);",
                  "pm.collectionVariables.set('activation_id', data.activation.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Public · Verify (con Bearer largo, retrocompat)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{session_token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/activation/verify",
